  "agent_roles": {
    "architect": {
      "description": "方案设计与质量管控",
      "priority": "critical",
      "token_share": "15%",
      "note": "Leader 承担部分编排职责后 architect 占比下降"
    },
    "coder-senior": {
      "description": "复杂代码实现（架构/安全/并发）",
      "priority": "high",
      "token_share": "15%"
    },
    "coder-standard": {
      "description": "常规业务代码实现",
      "priority": "high",
      "token_share": "25%"
    },
    "coder-lite": {
      "description": "简单代码实现（CRUD/配置/模板复制）",
      "priority": "medium",
      "token_share": "15%"
    },
    "reviewer": {
      "description": "代码审查（双 reviewer 并行：reviewer 主审实现可行性，reviewer-b 辅审技术合理性）",
      "priority": "high",
      "token_share": "15%",
      "note": "reviewer-b-model 在预设中定义第二个 reviewer 使用的模型，由 beggar-workflow 在评审时自动调用"
    },
    "tester": {
      "description": "测试运行与验证",
      "priority": "medium",
      "token_share": "10%"
    },
    "recorder": {
      "description": "知识沉淀与归档",
      "priority": "low",
      "token_share": "5%"
    },
    "goal-evaluator": {
      "description": "独立目标验证评估者，读取验证报告做 yes/no 判定",
      "priority": "medium",
      "token_share": "2%",
      "note": "用轻量模型（kimi-k2.5/hy3）做独立判定，避免 Leader 自判偏差。每轮迭代仅调用 1 次"
    },
    "director": {
      "description": "隐藏升级裁决 Agent，仅在 3 轮审查全败时激活",
      "model_note": "统一使用 GLM-5.1（公网版最强可用推理模型），做根因分析和最终裁决",
      "trigger": "3 轮 coder 全败 + Leader 根因分析后仍无法自行解决时激活一次"
    }
  },
  "complexity_routing": {
    "_note": "Leader 根据以下规则判断任务复杂度并分派对应 coder",
    "coder-lite": [
      "纯配置修改（env, json, yaml, toml）",
      "单字段增删改（CRUD 操作的单个字段）",
      "复制已有模式的重复代码",
      "修改常量、文案、样式值",
      "添加已有模板的 API route",
      "单行 bug 修复（逻辑明确）"
    ],
    "coder-standard": [
      "常规业务功能实现（有 design.md）",
      "非架构性 bug 修复",
      "新 API endpoint + 业务逻辑",
      "编写/更新单元测试",
      "前端新页面/组件（有参照）",
      "数据库迁移脚本"
    ],
    "coder-senior": [
      "架构变更或新模式引入",
      "跨模块/跨子项目联动修改",
      "性能优化、并发/分布式逻辑",
      "安全相关（认证、加密、权限）",
      "无先例的新功能",
      "低级 coder 2轮 review 未通过的升级任务"
    ]
  },
  "review_gate": {
    "_note": "Review 升级机制：coder 产出未通过 reviewer 时自动升级。3轮失败后进入应急处理而非直接抛给用户",
    "max_rounds": 3,
    "escalation": "coder-lite → coder-standard → coder-senior → 【Leader 根因分析】",
    "self_fix_before_escalation": 2,
    "self_fix_note": "编译/测试失败时同级 coder 先尝试自修复2次，超过才升级",
    "emergency_handling": {
      "trigger": "3 轮 review 都未通过（lite + standard + senior 均失败）",
      "leader_actions": [
        "根因分析：读取3轮实现报告+reviewer意见，判断失败类型",
        "设计缺陷 → architect 重新评估（最多1次修正机会）",
        "任务过大 → 拆分为更小的子任务（每个子任务独立3轮）",
        "reviewer 误判 → Leader 仲裁，接受实现并记录误判",
        "需求不清 → 向用户澄清，基于新理解重新分派",
        "环境问题 → 跳过环境阻塞，标记为已知问题",
        "能力天花板 → 用户裁决（最终兜底）"
      ]
    }
  }
}
